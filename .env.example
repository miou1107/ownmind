# Server
PORT=3000

# Database (use 'db' for Docker, 'localhost' for local dev)
DB_HOST=db
DB_PORT=5432
DB_NAME=ownmind
DB_USER=ownmind
DB_PASSWORD=your_secure_password_here

# Encryption (for secrets management, at least 32 chars)
ENCRYPTION_KEY=your_32_char_encryption_key_here

# Logging
LOG_LEVEL=info
