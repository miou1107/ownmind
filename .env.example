# Server
PORT=3000

# Database (use 'db' for Docker, 'localhost' for local dev)
DB_HOST=db
DB_PORT=5432
DB_NAME=ownmind
DB_USER=ownmind
DB_PASSWORD=your_secure_password_here

# Encryption (for secrets management, at least 32 chars; 未設定或使用預設值則拒絕啟動)
ENCRYPTION_KEY=your_32_char_encryption_key_here

# Setup token (首次設定 super_admin 密碼時必須帶此 token；未設定則 /setup 端點停用)
SETUP_TOKEN=

# CORS：允許跨域的 origin（留空則禁止所有跨域請求，建議不設定）
CORS_ORIGIN=

# Logging
LOG_LEVEL=info
