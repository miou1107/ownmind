#!/bin/sh
# OwnMind Git Pre-Commit Hook — Shell Wrapper
# Runs the Node.js pre-commit verification, then chains existing hooks if present.

node "$HOME/.ownmind/hooks/ownmind-git-pre-commit.js"
RESULT=$?
if [ $RESULT -ne 0 ]; then
  exit 1
fi

# Chain existing hooks (core.hooksPath 設定後 git 忽略 .git/hooks/，需要手動 chain)
# 1. 先檢查 repo 自己的 .git/hooks/pre-commit（被 core.hooksPath 覆蓋的原有 hook）
if [ -x "$(git rev-parse --git-dir 2>/dev/null)/hooks/pre-commit" ]; then
  "$(git rev-parse --git-dir)/hooks/pre-commit"
  exit $?
fi
# 2. 再檢查 .local 慣例（husky 等工具遷移後的 hook）
if [ -x .git/hooks/pre-commit.local ]; then
  .git/hooks/pre-commit.local
  exit $?
fi

exit 0
